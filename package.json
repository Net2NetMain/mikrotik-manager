{
  "name": "net2net-mikrotik-manager",
  "version": "4.0.0",
  "description": "Net2Net MikroTik Manager — Multi-router, Dashboard, Graphs, CSV Export",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "co.anysmart.net2net-manager",
    "productName": "Net2Net Manager",
    "copyright": "Copyright © 2026 Net2Net",
    "publish": {
      "provider": "github",
      "owner": "YOUR_GITHUB_USERNAME",
      "repo": "mikrotik-manager"
    },
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "icon.png"
    },
    "nsis": {
      "installerIcon": "icon.png",
      "shortcutName": "Net2Net Manager",
      "oneClick": true,
      "perMachine": false
    },
    "linux": { "target": "AppImage" },
    "files": [
      "main.js", "preload.js", "mikrotik-api.js", "ssh-test.js",
      "index.html", "icon.png", "splash.png", "node_modules/**/*"
    ]
  },
  "dependencies": {
    "node-routeros": "^1.5.2",
    "ssh2": "^1.15.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
